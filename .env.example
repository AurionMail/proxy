# SMTP proxy listener
LISTEN_ADDR=:25
DOMAIN=aurion.local
MAX_MESSAGE_BYTES=10485760   # 10 MiB

# Routing API (app-core)
ROUTING_URL=http://api.aurion.domain
ROUTING_TIMEOUT=3s

# Forwarding SMTP
FORWARD_ADDR=mail.aurion.domain:10025

# Queue
QUEUE_SIZE=1000
WORKER_COUNT=4

# TLS for incoming SMTP
TLS_CERT=server.crt
TLS_KEY=server.key
